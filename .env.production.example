# ============================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# ============================================

# Server
PORT=4000
NODE_ENV=production

# Database - Get this from your hosting platform (Render/Railway)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Frontend URL (for CORS) - Replace with your actual frontend URL
WEB_ORIGIN=https://your-frontend.onrender.com

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (.env.production)
# ============================================

# Socket.io WebSocket URL - Replace with your backend URL
VITE_SOCKET_URL=https://your-backend.onrender.com

# API Base URL (optional - defaults to /api proxy)
# VITE_API_URL=/api
