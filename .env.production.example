# ============================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# ============================================

# Server
PORT=4000
NODE_ENV=production

# Database - Get this from your hosting platform (Render/Railway)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Frontend URL (for CORS) - Replace with your actual frontend URL
WEB_ORIGIN=https://servv-psi.vercel.app

# ============================================
# FRONTEND ENVIRONMENT VARIABLES (Vercel dashboard)
# ============================================

# IMPORTANT: These must be set in Vercel project settings!

# Socket.io WebSocket URL - Your backend URL on Render
VITE_SOCKET_URL=https://scanner-3cku.onrender.com

# API Base URL - Your backend URL (include trailing slash if needed)
# This is used by src/api/http.ts to make API calls
VITE_API_URL=https://scanner-3cku.onrender.com
