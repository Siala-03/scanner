# Backend Environment Variables
# NOTE: For production on Render, set these in the Render dashboard

# Server
PORT=4000
NODE_ENV=production

# Database - Get from Render dashboard (Internal Database URL)
# DATABASE_URL=postgres://user:password@host.internal.render.com:5432/dbname

# Frontend URL (for CORS) - Must match your Vercel frontend URL (NO trailing slash!)
WEB_ORIGIN=https://servv-psi.vercel.app
